# Payments service — environment template
# LEAKTESTMARKER_ENVEXAMPLE
# Copy to .env and fill in real values. The values below are placeholders,
# NOT secrets — a correct redactor should leave them untouched.
NODE_ENV=development
PORT=8080

STRIPE_LIVE_KEY=sk_live_your_stripe_key_here
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=replace-with-your-aws-secret
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://user:password@localhost:5432/payments
